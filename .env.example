# Copy this file to .env and fill in your actual values
# cp .env.example .env

# ─── Server ─────────────────────────────────────────────
PORT=5000

# ─── Database ───────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/vyapar_db

# ─── Authentication ─────────────────────────────────────
# Use a long random string in production (min 32 characters)
JWT_SECRET=change_this_to_a_long_random_string

# ─── Backup ─────────────────────────────────────────────
# Path where backups are stored on the server
BACKUP_PATH=./backups

# ─── Admin Account ──────────────────────────────────────
# Email of the admin user who can manage backups
ADMIN_EMAIL=admin@shahin.com

# ─── CORS / Frontend ────────────────────────────────────
# Your production frontend URL (Netlify domain or custom domain)
FRONTEND_URL=https://yourapp.netlify.app

# ─── API Base URL ───────────────────────────────────────
API_BASE_URL=http://localhost:5000

# ─── Backup Schedule (optional) ─────────────────────────
# Cron expression for the auto-backup schedule
# Default: '0 0 * * *' (every day at midnight IST)
# BACKUP_CRON=0 0 * * *
